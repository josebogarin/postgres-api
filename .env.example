# ── Application ──────────────────────────────────────────────
APP_NAME="Postgres API"
APP_ENV=development          # development | staging | production
DEBUG=true
API_PREFIX=/api
API_V1_STR=/api/v1

# ── Security ─────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-ME-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Default superuser ────────────────────────────────────────
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=changeme123

# ── Primary database (user management) ───────────────────────
# Local (fuera de Docker): host=localhost
# Docker Compose:          host=db
DATABASE_URL=postgresql+asyncpg://app_user:superpassword@localhost:5432/users_db

# ── Additional application databases (JSON map) ──────────────
# APP_DATABASES={"app1":"postgresql+asyncpg://user:pass@host/app1_db","app2":"postgresql+asyncpg://user:pass@host/app2_db"}
APP_DATABASES={}

# ── CORS ─────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json              # json | console
